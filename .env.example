# =============================================================================
# FitFlow environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values for local development.
# The same variables must be set as GitHub Actions secrets for CI / deploys.
# Vars prefixed VITE_ are exposed to the client bundle — never put secret keys there.
# =============================================================================

# --- Google Gemini ----------------------------------------------------------
# DEV ONLY: direct SDK key. Bundled into the client — fine for local development,
# never set in production. In production set VITE_GEMINI_PROXY_URL instead and
# the client will route through the Cloud Function (which holds the real key).
GEMINI_API_KEY=

# PROD: URL of the deployed `geminiProxy` Cloud Function.
# Format: https://us-central1-<projectId>.cloudfunctions.net/geminiProxy
VITE_GEMINI_PROXY_URL=

# --- Stripe billing ---------------------------------------------------------
# URL of the deployed `createCheckoutSession` Cloud Function.
VITE_STRIPE_CHECKOUT_URL=

# Stripe Price IDs (price_..., from Stripe dashboard → Products)
VITE_STRIPE_PRICE_MONTHLY=
VITE_STRIPE_PRICE_YEARLY=

# --- Telemetry --------------------------------------------------------------
# Sentry DSN from https://sentry.io → project → Settings → Client Keys
VITE_SENTRY_DSN=

# PostHog from https://posthog.com → Project → Settings → API Keys
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# --- App metadata -----------------------------------------------------------
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# --- Firebase Web messaging VAPID -------------------------------------------
# From Firebase Console → Project Settings → Cloud Messaging → Web Push certs
VITE_FIREBASE_VAPID_KEY=

# --- App URL (used for OAuth callbacks and self-referential links) ----------
APP_URL=http://localhost:3000

# --- Optional: USDA food database -------------------------------------------
VITE_USDA_API_KEY=DEMO_KEY
