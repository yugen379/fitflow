# Copy this file to `keystore.properties` (gitignored) and fill in the values
# created when you generated your signing keystore with:
#
#   keytool -genkey -v -keystore fitflow-release.keystore -alias fitflow \
#           -keyalg RSA -keysize 2048 -validity 10000
#
# DO NOT COMMIT the resulting keystore file or this populated properties file.
# Back up the keystore — losing it means you cannot publish updates to your app.

storeFile=/absolute/path/to/fitflow-release.keystore
storePassword=REPLACE_WITH_STORE_PASSWORD
keyAlias=fitflow
keyPassword=REPLACE_WITH_KEY_PASSWORD
